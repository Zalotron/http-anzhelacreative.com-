---
import cv from '~/data/cv.json';
import SectionHeader from './SectionHeader.astro';
import Particles from './Particles.astro';

const areas = [
  'Identidad de marca',
  'Diseño UX/UI',
  'Sistemas de diseño',
  'Ilustración',
  'Motion graphics',
  'Retoque & edición',
  'Tipografía',
  'Editorial',
];
---

<section id="about" class="relative py-16 md:py-20 overflow-hidden">
  <!-- Depth back: palabra gigante outline + blur (lejana, fuera de foco) -->
  <span
    aria-hidden="true"
    data-depth="back"
    data-depth-blur="3"
    data-depth-rotate="-3"
    class="pointer-events-none select-none absolute -bottom-8 -left-12 heading-display text-[22vw] font-bold leading-none"
    style="color: transparent; -webkit-text-stroke: 1px var(--color-ink-faint); opacity: 0.3;"
  >
    Diseño
  </span>

  <!-- Depth mid: chevron + asterisco -->
  <span
    aria-hidden="true"
    data-depth="mid"
    data-depth-rotate="15"
    class="pointer-events-none absolute top-1/3 right-[8%] text-[var(--color-accent)]/50 text-5xl"
  >→</span>
  <span
    aria-hidden="true"
    data-depth="mid"
    data-depth-rotate="-25"
    class="pointer-events-none absolute bottom-1/4 right-[20%] text-[var(--color-ink-faint)] text-6xl font-display"
  >✳</span>

  <Particles count={22} seed={23} />
  <SectionHeader
    number="02"
    label="Sobre mí"
    title="Diseño con intención.<br/>Ejecuto con <span style='color:var(--color-accent)'>oficio</span>."
  />

  <div class="container-page max-w-5xl relative z-10">
    <p
      data-scatter-words="0.7"
      class="text-xl md:text-2xl font-light leading-relaxed text-[var(--color-ink)]"
    >
      {cv.profile.bio}
    </p>

    <div class="mt-10">
      <p data-scatter="0.4" class="label-mono mb-6">Áreas de trabajo</p>
      <div class="flex flex-wrap gap-3">
        {
          areas.map((area, i) => (
            <span
              data-scatter={(0.5 + (i % 3) * 0.15).toFixed(2)}
              class="px-4 py-2 border border-[var(--color-border)] rounded-full label-mono hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
            >
              {area}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
