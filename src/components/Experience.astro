---
import cv from '~/data/cv.json';
import { formatRange, durationLabel, pad } from '~/lib/format';
import SectionHeader from './SectionHeader.astro';
---

<section id="experience" class="relative py-16 md:py-20 overflow-hidden">
  <!-- BACK: palabra gigante outline + número con blur -->
  <span
    aria-hidden="true"
    data-depth="back"
    data-depth-blur="3"
    data-depth-rotate="-2"
    class="pointer-events-none select-none absolute top-1/4 -right-12 heading-display text-[18vw] font-bold tracking-tighter"
    style="color: transparent; -webkit-text-stroke: 1px var(--color-ink-faint); opacity: 0.3;"
  >
    Trabajo
  </span>
  <span
    aria-hidden="true"
    data-depth="back"
    data-depth-blur="2"
    class="pointer-events-none select-none absolute top-2/3 -left-8 heading-display text-[16vw] font-bold leading-none"
    style="color: transparent; -webkit-text-stroke: 1px var(--color-ink-faint); opacity: 0.2;"
  >
    03
  </span>

  <!-- MID: símbolos rotando -->
  <svg
    aria-hidden="true"
    data-depth="mid"
    data-depth-rotate="-15"
    class="pointer-events-none absolute bottom-1/3 right-[8%] w-12 h-12 text-[var(--color-ink-faint)]"
    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"
  >
    <circle cx="12" cy="12" r="11"/>
  </svg>


  <SectionHeader
    number="03"
    label="Experiencia"
    title="Trabajo real.<br/><span style='color:var(--color-accent)'>Resultados</span> reales."
    subtitle={`${cv.experience.length} posiciones, agencias y startups donde diseñé identidades, interfaces y campañas digitales.`}
  />

  <div class="container-page relative z-10 space-y-4">
    {
      cv.experience.map((job, i) => (
        <div data-scatter={(0.4 + i * 0.05).toFixed(2)}>
        <article
          data-tilt="3"
          class="group relative grid md:grid-cols-12 gap-4 md:gap-10 p-5 md:p-8 border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)] transition-colors duration-500"
        >
          <div class="md:col-span-3 flex md:flex-col justify-between gap-4">
            <span data-scatter="0.5" class="font-mono text-xs text-[var(--color-ink-faint)]">
              {pad(i + 1, 2)} / {pad(cv.experience.length, 2)}
            </span>
            <div data-scatter="0.55" class="text-right md:text-left">
              <p class="font-mono text-xs text-[var(--color-ink-dim)] uppercase tracking-widest">
                {formatRange(job.start, job.end)}
              </p>
              <p class="font-mono text-xs text-[var(--color-accent)] mt-1">
                {durationLabel(job.start, job.end)}
              </p>
            </div>
          </div>

          <div class="md:col-span-9">
            <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-2">
              <h3
                data-scatter-letters="0.7"
                class="font-display text-3xl md:text-5xl leading-none tracking-tight"
              >
                {job.company}
              </h3>
              <span data-scatter="0.7" class="label-mono">{job.location}</span>
            </div>
            <p
              data-scatter="0.5"
              class="font-display font-medium text-xl md:text-2xl text-[var(--color-accent)] mb-4"
            >
              {job.role}
            </p>
            {job.context && (
              <p data-scatter-words="0.55" class="text-[var(--color-ink-dim)] mb-6 max-w-2xl">{job.context}</p>
            )}
            <ul class="space-y-2 max-w-3xl">
              {job.highlights.map((point, hi) => (
                <li class="flex gap-3 text-[var(--color-ink)] leading-relaxed">
                  <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">→</span>
                  <span data-scatter-words={(0.45 + (hi % 4) * 0.1).toFixed(2)}>{point}</span>
                </li>
              ))}
            </ul>
          </div>

          <div
            class="absolute top-0 right-0 w-16 h-16 border-t border-r border-transparent group-hover:border-[var(--color-accent)] transition-colors duration-500 pointer-events-none"
          />
          <div
            class="absolute bottom-0 left-0 w-16 h-16 border-b border-l border-transparent group-hover:border-[var(--color-accent)] transition-colors duration-500 pointer-events-none"
          />
          <!-- Número gigante en background interno de cada card -->
          <span
            aria-hidden="true"
            class="absolute -right-2 -bottom-6 font-display font-bold text-[8rem] md:text-[12rem] leading-none pointer-events-none select-none"
            style="color: transparent; -webkit-text-stroke: 1px var(--color-border); opacity: 0.5;"
          >
            {pad(i + 1, 2)}
          </span>
        </article>
        </div>
      ))
    }
  </div>
</section>
