---
import cv from '~/data/cv.json';
import Particles from './Particles.astro';

const [firstName, ...lastNameParts] = cv.profile.name.split(' ');
const lastName = lastNameParts.join(' ');
const visibleSocial = cv.profile.social.filter((s) => !s.url.startsWith('TODO_'));
---

<section
  id="top"
  data-cursor-glow
  class="relative flex flex-col overflow-hidden pt-20 pb-10"
>
  <!-- BACK: paralax background layers (lentas, lejos) -->
  <div
    data-parallax="0.4"
    class="absolute inset-0 bg-grid opacity-50 pointer-events-none"
  >
  </div>
  <div
    aria-hidden="true"
    data-parallax="0.6"
    class="absolute -top-32 -right-32 w-[40rem] h-[40rem] rounded-full bg-[var(--color-accent)]/5 blur-3xl pointer-events-none"
  >
  </div>
  <div
    aria-hidden="true"
    data-parallax="0.8"
    class="absolute -bottom-40 -left-20 w-[30rem] h-[30rem] rounded-full bg-[var(--color-accent-2)]/10 blur-3xl pointer-events-none"
  >
  </div>

  <!-- BACK: año gigante outline en background -->
  <span
    aria-hidden="true"
    data-depth="back"
    data-depth-blur="2"
    class="pointer-events-none select-none absolute -top-8 right-8 heading-display text-[28vw] font-bold leading-none"
    style="color: transparent; -webkit-text-stroke: 1px var(--color-border); opacity: 0.5;"
  >
    {new Date().getFullYear()}
  </span>

  <!-- MID: símbolos rotando -->
  <span
    aria-hidden="true"
    data-depth="mid"
    data-depth-rotate="20"
    class="pointer-events-none absolute top-44 right-[12%] text-[var(--color-accent-2)] text-7xl md:text-9xl font-display font-light opacity-40"
  >✳</span>
  <svg
    aria-hidden="true"
    data-depth="mid"
    data-depth-rotate="-30"
    class="pointer-events-none absolute bottom-1/4 left-[15%] w-10 h-10 text-[var(--color-ink-faint)]"
    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"
  >
    <path d="M12 2v20M2 12h20" />
  </svg>

  <!-- Campo de partículas luminosas con depth random -->
  <Particles count={28} seed={11} />

  <!-- Top bar -->
  <div class="container-page relative z-10 flex items-start justify-between gap-8">
    <p data-scatter="0.4" class="label-mono flex items-center gap-3">
      <span class="w-8 h-px bg-[var(--color-accent)]"></span>
      {cv.profile.role}
    </p>
    <span data-scatter="0.4" class="label-mono text-right">
      <span class="text-[var(--color-accent-2)]">●</span> Disponible
    </span>
  </div>

  <!-- Nombre alineado al container -->
  <div class="container-page relative z-10 mt-6 md:mt-8">
    <h1 class="heading-display mb-2 leading-none">
      <span class="block overflow-hidden">
        <span data-hero-title data-hero-scatter="0.6" class="block whitespace-nowrap" data-fit-text>{firstName}</span>
      </span>
      <span class="block overflow-hidden text-[var(--color-accent)]">
        <span data-hero-title data-hero-scatter="0.7" class="block whitespace-nowrap" data-fit-text>{lastName}</span>
      </span>
    </h1>
  </div>

  <!-- Foto + datos esenciales -->
  <div class="container-page relative z-10 mt-10 md:mt-12 grid md:grid-cols-12 gap-8 md:gap-10 items-start">
    <!-- Foto -->
    <div data-scatter="0.5" class="md:col-span-4">
      <div
        data-tilt="3"
        class="group relative aspect-[4/5] overflow-hidden bg-[var(--color-surface)] border border-[var(--color-border)]"
      >
        <img
          src={cv.profile.photo}
          alt={cv.profile.name}
          width="800"
          height="1000"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]"
        />
        <div
          class="absolute top-0 left-0 right-0 flex items-center justify-between p-3 label-mono mix-blend-difference text-[var(--color-ink)]"
        >
          <span>{cv.profile.shortName}</span>
          <span>{new Date().getFullYear()}</span>
        </div>
      </div>
    </div>

    <!-- Datos esenciales: cada uno con scatter independiente -->
    <div class="md:col-span-8 grid md:grid-cols-2 gap-y-8 gap-x-10 md:pt-2">
      <div data-scatter="0.55">
        <p class="label-mono mb-3">Email</p>
        <a
          href={`mailto:${cv.profile.email}`}
          class="font-display text-xl md:text-2xl link-underline hover:text-[var(--color-accent)] transition-colors break-all"
        >
          {cv.profile.email}
        </a>
      </div>
      <div data-scatter="0.5">
        <p class="label-mono mb-3">Ubicación</p>
        <p class="font-display text-xl md:text-2xl">{cv.profile.location}</p>
      </div>
      <div data-scatter="0.6">
        <p class="label-mono mb-3">Experiencia</p>
        <p class="font-display text-xl md:text-2xl">
          3+ años · Diseño & UX/UI
        </p>
      </div>
      <div data-scatter="0.55">
        <p class="label-mono mb-3">Online</p>
        <div class="flex flex-wrap gap-3">
          {
            visibleSocial.map((s) => (
              <a
                href={s.url}
                target={s.url.startsWith('http') ? '_blank' : undefined}
                rel="noopener noreferrer"
                class="px-3 py-1 border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] label-mono transition-colors"
              >
                {s.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom -->
  <div
    data-scatter="0.4"
    class="container-page relative z-10 mt-10 md:mt-14 flex items-center justify-between label-mono text-[var(--color-ink-faint)]"
  >
    <span>(01) Inicio</span>
    <a href="#about" class="hover:text-[var(--color-accent)] transition-colors flex items-center gap-3">
      <span class="w-12 h-px bg-current"></span>
      Scroll para explorar
    </a>
    <span>{new Date().getFullYear()} ©</span>
  </div>
</section>
